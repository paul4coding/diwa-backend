# ──────────────────────────────────────────────────────────────────
# DIWA Backend — Variables d'environnement (production)
# Ces variables sont injectées via Docker / Portainer secrets
# ──────────────────────────────────────────────────────────────────

# ── Base de données ──────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/DIWA_DB
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# ── JWT ──────────────────────────────────────────────────────────
DIWA_APP_JWT_SECRET=changeme_minimum_32_characters_long_secret_key
DIWA_APP_JWT_EXPIRATION_MS=28800000

# ── Email Gmail ──────────────────────────────────────────────────
SPRING_MAIL_USERNAME=votre-email@gmail.com
SPRING_MAIL_PASSWORD=votre_app_password_gmail

# ── Application ──────────────────────────────────────────────────
APP_FRONTEND_URL=https://votre-domaine.com
APP_MAIL_FROM=votre-email@gmail.com
APP_UPLOAD_DIR=/app/uploads

# ── PostgreSQL (pour docker-compose.yml) ─────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# ── Mot de passe admin initial ───────────────────────────────────
# Changement obligatoire au premier login
DIWA_ADMIN_PASSWORD=ChangeMe!PremierLogin
